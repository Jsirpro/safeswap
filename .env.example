# Backend HTTP port
SAFE_SWAP_PORT=4000

# Frontend API origin
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Remote whitelist source used when MOCK_MODE=false
REMOTE_WHITELIST_URL=http://localhost:4010/whitelist

# Unexpired whitelist cache is required for new flows
WHITELIST_CACHE_TTL_MS=300000

# Quote integration mode; mock is the current implementation
QUOTE_PROVIDER_MODE=mock

# Reserved Sui RPC endpoint for signing/execution handoff
SUI_RPC_URL=https://fullnode.mainnet.sui.io

# Enables mock whitelist, mock quotes, and mock wallet signature flow
MOCK_MODE=true
